lxc.apparmor.profile = generated
lxc.apparmor.allow_nesting = 0

lxc.net.0.name = eth0
lxc.net.0.type = veth
{% if lxc_network_type == "host_bridge" %}
lxc.net.0.link = br0
{% else %}
lxc.net.0.link = lxcbr0
{% endif %}
lxc.net.0.flags = up

lxc.start.auto = 1
lxc.start.delay = 10
lxc.start.order = 99
