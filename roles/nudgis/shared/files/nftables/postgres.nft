# Postgres firewall rule definition
table inet filter {
    # Allowed clients
    set postgres_clients {
        type ipv4_addr
        flags interval
        elements = {
            # DB servers for replication
            # front servers for SQL acess
            0.0.0.0/0,        # all
        }
    }
    # Firewall rule
    chain input {
        ip saddr @postgres_clients tcp dport 5432 accept comment "PostgreSQL"
    }
}
