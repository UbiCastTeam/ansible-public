# APT Cacher firewall rule definition
table inet filter {
    # Allowed clients
    set apt_cacher_clients {
        type ipv4_addr
        flags interval
        elements = {
            0.0.0.0/0,        # all
        }
    }
    # Firewall rule
    chain input {
        ip saddr @apt_cacher_clients tcp dport 3142 accept comment "APT Cacher"
    }
}
