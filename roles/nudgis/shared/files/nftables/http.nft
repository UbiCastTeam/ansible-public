# HTTP(S) firewall rule definition
table inet filter {
    # Allowed clients
    set http_clients {
        type ipv4_addr
        flags interval
        elements = {
            # viewers, CDN, ... for web access
            0.0.0.0/0,        # all
        }
    }
    # Firewall rule
    chain input {
        ip saddr @http_clients tcp dport { 80, 443 } accept comment "HTTP(S)"
    }
}
